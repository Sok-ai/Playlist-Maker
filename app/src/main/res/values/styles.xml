<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="BaseButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:gravity">center</item>
        <item name="android:inputType">textCapWords</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textSize">@dimen/main_size_text</item>
        <item name="cornerRadius">@dimen/btn_radius</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textIsSelectable">false</item>
    </style>

    <style name="PrimaryButtonStyle" parent="BaseButtonStyle"></style>

    <style name="SecondaryButtonStyle" parent="BaseButtonStyle">
        <item name="cornerRadius">@dimen/main_btn_radius</item>
        <item name="android:textColor">@color/YP_Black</item>
        <item name="iconGravity">textStart</item>
        <item name="iconTint">@color/YP_Black</item>
        <item name="android:backgroundTint">@color/YP_White</item>
        <item name="iconPadding">8dp</item>
    </style>

    <style name="ImageButtonStyle" parent="BaseButtonStyle">
        <item name="tint">?attr/colorOnPrimary</item>
        <item name="android:backgroundTint">?attr/colorSecondary</item>
    </style>

    <style name="TitleTextStyle">
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textSize">@dimen/main_size_title</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>

    </style>

    <style name="NormalTextStyle">
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textSize">@dimen/main_size_title</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:layout_gravity">center</item>
    </style>

    <style name="SettingsOptionsTextStyle" parent="NormalTextStyle">
        <item name="android:textStyle">normal</item>
        <item name="android:textSize">@dimen/settings_size_text</item>
    </style>

    <style name="SwitchStyle" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="android:thumbTint">@color/YP_Turquoise</item>
        <item name="android:trackTint">@color/YP_Turquoise_Light</item>
    </style>

    <style name="ImageViewStyle">
        <item name="android:importantForAccessibility">no</item>
        <item name="android:scaleType">fitCenter</item>
        <item name="tint">@color/YP_Text_Gray</item>
    </style>
</resources>