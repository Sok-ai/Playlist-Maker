<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="BaseButtonStyle" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:gravity">center</item>
        <item name="android:inputType">textCapWords</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textSize">@dimen/text_body_size</item>
        <item name="cornerRadius">@dimen/radius_medium</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
    </style>

    <style name="EditTextStyle.Base" parent="NormalTextStyle">
        <item name="android:drawablePadding">8dp</item>
        <item name="android:paddingVertical">10dp</item>
        <item name="android:paddingStart">13dp</item>
        <item name="android:maxLength">30</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">@color/YP_Black</item>
    </style>
</resources>