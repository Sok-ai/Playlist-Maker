<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TitleTextStyle">
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textSize">@dimen/text_title_size</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="fontWeight">500</item>
    </style>

    <style name="NormalTextStyle">
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textSize">@dimen/text_subtitle_size</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="fontWeight">400</item>
    </style>

    <style name="ErrorTextStyle">
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textSize">@dimen/text_error_size</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="fontWeight">400</item>
    </style>

    <style name="SearchHistoryTextStyle">
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textSize">@dimen/text_search_history_size</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="fontWeight">500</item>
    </style>

    <style name="InfoTextStyle" parent="NormalTextStyle">
        <item name="android:textColor">?attr/textColorInfo</item>
        <item name="android:textSize">@dimen/text_info_size</item>
    </style>

    <style name="SettingsOptionsTextStyle" parent="NormalTextStyle">
        <item name="android:textStyle">normal</item>
    </style>
</resources>